{
  "name": "@faraday-academy/platform-contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Zod contracts for Faraday Stage 2 platform (course, LMS, assessment, entitlement, release, UGC bridge).",
  "exports": {
